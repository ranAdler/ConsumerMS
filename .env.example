# Consumer Microservice Environment Configuration
# Copy this file to .env and update values as needed

# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=consumer_db
MYSQL_USER=consumer_user
MYSQL_PASSWORD=consumer_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=consumer-service-group

# Spring Boot Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/consumer_db?useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=consumer_user
SPRING_DATASOURCE_PASSWORD=consumer_password

# Application Configuration
SERVER_PORT=8080
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_CONSUMERSMS=DEBUG